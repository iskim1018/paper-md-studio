{
  "name": "paper-md-studio",
  "version": "0.1.0",
  "private": true,
  "description": "macOS 문서 변환 도구 - HWP(X), DOC(X), PDF를 Markdown으로 변환",
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "build:hwp-tool": "cd tools/hwp-to-hwpx && mvn -B clean package && cp target/hwp-to-hwpx.jar ../../packages/core/resources/hwp-to-hwpx.jar",
    "dev": "pnpm -r dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "pnpm -r typecheck",
    "security": "pnpm audit",
    "prepare": "lefthook install"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.33.0",
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.5.2",
    "@vitest/coverage-v8": "^4.1.2",
    "lefthook": "^2.1.5",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
