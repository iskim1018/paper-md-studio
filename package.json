{
  "name": "paper-md-studio",
  "version": "0.1.0",
  "private": true,
  "description": "HWP, HWPX, DOCX, PDF 문서를 Markdown으로 변환·편집하는 크로스플랫폼 데스크톱 앱 (macOS Apple Silicon + Windows 11)",
  "keywords": [
    "hwp",
    "hwpx",
    "docx",
    "pdf",
    "markdown",
    "converter",
    "editor",
    "tauri",
    "korean",
    "hangul"
  ],
  "author": "Insung Kim",
  "license": "MIT",
  "homepage": "https://github.com/iskim/paper-md-studio",
  "repository": {
    "type": "git",
    "url": "https://github.com/iskim/paper-md-studio.git"
  },
  "bugs": {
    "url": "https://github.com/iskim/paper-md-studio/issues"
  },
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "build:hwp-tool": "cd tools/hwp-to-hwpx && mvn -B clean package && cp target/hwp-to-hwpx.jar ../../packages/core/resources/hwp-to-hwpx.jar",
    "build:jre": "node scripts/build-jre.mjs",
    "build:node": "node scripts/bundle-node.mjs",
    "build:cli-bundle": "pnpm --filter @paper-md-studio/cli build:bundle",
    "build:app-resources": "node scripts/prepare-app-resources.mjs",
    "build:dist": "pnpm build && pnpm build:hwp-tool && pnpm build:jre && pnpm build:node && pnpm build:cli-bundle && pnpm build:app-resources",
    "dev": "pnpm -r dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "pnpm -r typecheck",
    "security": "pnpm audit",
    "prepare": "lefthook install"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.33.0",
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.5.2",
    "@vitest/coverage-v8": "^4.1.2",
    "lefthook": "^2.1.5",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
