# paper-md-studio server — 환경변수 예시
# 9-18에서 CONFIG.md와 함께 상세화 예정

PORT=3000
HOST=0.0.0.0
STORAGE_ROOT=./.paper-md-storage

# 콤마 구분 리스트. 비어있으면 인증 비활성 (개발 전용)
# 값이 하나라도 있으면 X-API-Key 헤더 검증이 활성화되고 /v1/health 외 모든 경로는 401 차단
API_KEYS=

# HMAC-SHA256 시크릿. API Key 비교 해싱, signed URL(9-6) 에 공용 사용
# 최소 16자. 프로덕션에서 반드시 교체할 것
SIGNING_SECRET=dev-secret-change-me-0123456789

SIGNED_URL_TTL_SECONDS=900
MAX_UPLOAD_MB=50

# /v1/convert?images=urls 응답에서 절대 URL 을 만들 때 사용. 비워두면 경로만 반환.
# 예: https://api.example.com (끝의 슬래시는 자동 제거)
PAPER_MD_PUBLIC_BASE_URL=

# /v1/convert?images=inline 으로 base64 인라인할 때 이미지 1장당 허용 크기 (KB).
# 초과 시 413 응답. 대용량은 ?images=urls / ?images=refs 사용 권장.
PAPER_MD_PUBLIC_MAX_INLINE_KB=512

RATE_LIMIT_PER_MINUTE=60
LOG_LEVEL=info
