{
  "name": "@paper-md-studio/cli",
  "version": "0.1.1",
  "private": true,
  "description": "paper-md-studio CLI 인터페이스",
  "author": "Insung Kim",
  "license": "MIT",
  "type": "module",
  "bin": {
    "paper-md-studio": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm",
    "build:bundle": "cross-env BUILD_BUNDLE=1 tsup",
    "dev": "tsup src/index.ts --format esm --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@paper-md-studio/core": "workspace:*"
  },
  "files": [
    "dist"
  ],
  "devDependencies": {
    "cross-env": "^10.1.0"
  }
}
