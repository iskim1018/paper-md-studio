{
  "$schema": "https://raw.githubusercontent.com/nicosResworworworworworking/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Paper MD Studio",
  "version": "0.1.0",
  "identifier": "com.paper-md-studio.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "Paper MD Studio",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/paper-md-studio-cli"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
