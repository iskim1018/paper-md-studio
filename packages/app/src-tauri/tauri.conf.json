{
  "$schema": "https://raw.githubusercontent.com/nicosResworworworworworking/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "docs-to-md",
  "version": "0.1.0",
  "identifier": "com.docs-to-md.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "docs-to-md",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/docs-to-md-cli"
    ]
  },
  "plugins": {
    "shell": {
      "sidecar": true,
      "scope": [
        {
          "name": "binaries/docs-to-md-cli",
          "sidecar": true,
          "args": true
        }
      ]
    }
  }
}
