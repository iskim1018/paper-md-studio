{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "Paper MD Studio",
  "version": "0.1.0",
  "identifier": "com.paper-md-studio.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "Paper MD Studio",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Productivity",
    "copyright": "Copyright (c) 2026 Insung Kim",
    "shortDescription": "HWP/HWPX/DOCX/PDF를 Markdown으로 변환·편집",
    "longDescription": "Paper MD Studio는 HWP, HWPX, DOCX, PDF 문서를 Markdown으로 변환하고 그 자리에서 WYSIWYG/소스/분할 모드로 편집할 수 있는 크로스플랫폼 데스크톱 앱입니다. 표 셀 내부 이미지 추출, 스타일(볼드/이탈릭/취소선) 보존, 배치 변환, 다크모드 등을 지원합니다.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/paper-md-studio-cli"
    ],
    "resources": {
      "resources/jre": "resources/jre",
      "resources/hwp-to-hwpx.jar": "resources/hwp-to-hwpx.jar"
    },
    "macOS": {
      "minimumSystemVersion": "12.0"
    },
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
