{
  "identifier": "default",
  "description": "기본 앱 권한",
  "windows": ["main"],
  "permissions": [
    "core:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "binaries/paper-md-studio-cli",
          "sidecar": true,
          "args": true
        }
      ]
    },
    "shell:allow-open",
    "dialog:allow-open",
    "dialog:allow-save",
    "fs:allow-read-file",
    "fs:allow-write-text-file",
    "fs:default"
  ]
}
