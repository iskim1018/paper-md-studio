{
  "name": "@paper-md-studio/core",
  "version": "0.1.1",
  "private": true,
  "description": "문서 변환 엔진 - HWP, HWPX, DOCX, PDF를 Markdown으로 변환",
  "author": "Insung Kim",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "typecheck": "tsc --noEmit"
  },
  "files": [
    "dist",
    "resources"
  ],
  "devDependencies": {
    "@types/turndown": "^5.0.6"
  },
  "dependencies": {
    "@opendocsg/pdf2md": "^0.2.6",
    "fast-xml-parser": "^5.7.0",
    "fflate": "^0.8.2",
    "mammoth": "^1.12.0",
    "turndown": "^7.2.4",
    "turndown-plugin-gfm": "^1.0.2"
  }
}
