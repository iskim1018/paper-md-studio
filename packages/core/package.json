{
  "name": "@docs-to-md/core",
  "version": "0.1.0",
  "private": true,
  "description": "문서 변환 엔진 - HWPX, DOCX, PDF를 Markdown으로 변환",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "typecheck": "tsc --noEmit"
  },
  "files": ["dist"]
}
