packages/app/sidecar-shim/target/
# Phase 7-D: jlink로 생성되는 번들 JRE (빌드 산출물, pnpm build:jre로 재생성)
**/src-tauri/resources/jre/
**/src-tauri/resources/jre.tar.gz
# Phase 7-E: 번들된 Node 런타임, CLI (pnpm build:node / build:cli-bundle + build:app-resources)
**/src-tauri/resources/node/
**/src-tauri/resources/cli/
# Tauri에 번들될 hwp2hwpx jar (core에서 복사되어 app resources로 오는 생성물)
packages/app/src-tauri/resources/hwp-to-hwpx.jar
# tsup 배포용 번들 산출물
packages/cli/dist-bundle/

# Maven (tools/hwp-to-hwpx)
tools/**/target/
tools/**/dependency-reduced-pom.xml

# Playwright
playwright-report/
test-results/

# Test fixture samples (보안상 실제 문서는 저장소에 포함하지 않음)
# 개발자는 로컬에 packages/core/tests/fixtures/ 아래 sample.{hwp,hwpx,docx,pdf},
# sample-with-image.docx를 직접 배치. 샘플이 없으면 관련 테스트는 자동 skip.
packages/core/tests/fixtures/*.hwp
packages/core/tests/fixtures/*.hwpx
packages/core/tests/fixtures/*.docx
packages/core/tests/fixtures/*.pdf
packages/core/tests/fixtures/*.md
packages/core/tests/fixtures/*_images/
!packages/core/tests/fixtures/README.md

# TypeScript build info
*.tsbuildinfo

# Claude Code — 공유: settings.json, rules/, skills/{convert-test,doc-update,security-check}/
# 제외: 개인 데이터 · 로컬 초안 · 이전 실험 잔재
.claude/memory/
.claude/plan/
.claude/settings.local.json

# git history 재작성 전 백업 (로컬 전용)
.git.backup/

# Logs
*.log
npm-debug.log*
